<cell valign="middle" halign ="center"><m>100</m></cell>
</row>
<row valign="top">
<cell valign="middle" halign ="left"><emphasis effect="bold"><m>\text{ ln }(x)</m></emphasis></cell>
<cell valign="middle" halign ="center"><m>-4.605</m></cell>
<cell valign="middle" halign ="center"><m>-2.303</m></cell>
